# ─────────────────────────────────────────────────────────────────────────────
# coach-platform API — environment template.
# Copy to `.env` and fill in real values. Keys are validated at boot by
# src/config/env.validation.ts (the app fails fast on missing/invalid values).
# Generate secrets with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000

# ── REQUIRED — boot fails if missing ────────────────────────────────────────
# MongoDB connection (mongodb:// or mongodb+srv://)
MONGO_URL=mongodb://localhost:27017/coach_platform

# 32 bytes hex-encoded => exactly 64 hex chars. Encrypts stored integration
# refresh tokens (AES-256-GCM). Generate: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=replace_with_64_hex_chars

# JWT signing — two DISTINCT secrets, min 32 chars each. openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_min_32_char_secret
JWT_REFRESH_SECRET=replace_with_a_DIFFERENT_min_32_char_secret

# Garmin fetch microservice base URL (the Python fetch-service)
FETCHER_BASE_URL=http://localhost:8000

# ── OPTIONAL — sensible defaults, override as needed ─────────────────────────
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# Comma-separated allowed browser origins. Unset => CORS disabled (dev uses a
# same-origin Vite proxy).
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

FETCHER_TIMEOUT_MS=120000
INGESTION_BACKFILL_DAYS=3

# Google Calendar per-user OAuth ("Web application" client). Leave empty to
# disable the Connect-Google-Calendar flow (endpoint returns 503 instead).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# ── AGENT LAYER (LLM + orchestrator) ─────────────────────────────────────────
# OPENAI_API_KEY is OPTIONAL for boot, but EVERY agent feature (chat, re-plan,
# approvals regeneration, triggers) returns 503 OPENAI_NOT_CONFIGURED until set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Backs the per-user single-flight pipeline queue + idempotency store. Defaults
# to localhost; MUST be set to your managed Redis URL in production (a wrong
# value fails silently at runtime, not at boot).
REDIS_URL=redis://localhost:6379
